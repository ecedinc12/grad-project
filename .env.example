# ============================================================
# SDG Pipeline — Ortam Değişkenleri Şablonu
# Kopyalayın: cp .env.example .env  (asla .env'i commit etmeyin)
# ============================================================

# --- RunPod (backend) & Droplet (frontend) ortak ---
# Her iki ucun da aynı değeri kullanması gerekir.
DROPLET_API_KEY=buraya-gizli-anahtar-yazin

# --- Yalnızca DigitalOcean Droplet (ui/app.py) ---
# RunPod HTTP Service URL'si (kontrol paneli → HTTP Services → port 8000)
BACKEND_URL=https://<pod-id>-8000.proxy.runpod.net

# --- Yalnızca RunPod (api/server.py + run_pipeline.sh) ---
GEMINI_API_KEY=buraya-gemini-api-key-yazin
ACCEPT_EULA=Y

# --- Geliştirme / test ---
# 1 → her zaman mock akış (gerçek pipeline çalıştırılmaz)
# 0 → BACKEND_URL tanımlıysa gerçek akış, tanımlı değilse mock
GRADIO_MOCK=0
