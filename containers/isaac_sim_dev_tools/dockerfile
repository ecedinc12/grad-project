FROM nvcr.io/nvidia/isaac-sim:5.1.0

USER root

RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    nano \
    curl \
    wget \
    python3-dev \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# LLM pipeline dependencies
RUN pip3 install --no-cache-dir --break-system-packages \
    "instructor>=1.6.0" \
    "openai>=1.30.0" \
    "pydantic>=2.0.0" \
    "numpy>=1.24.0,<2.0.0" \
    "Pillow>=10.0.0" \
    "huggingface_hub>=0.20.0"